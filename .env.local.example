# ─────────────────────────────────────────────────────────────────────────────
# Pen & Paper Two — environment template
# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — see https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — see https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe products (set after running `stripe products create`)
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ANNUAL=

# Site base URL (used by Stripe checkout success/cancel URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
